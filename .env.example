# Backend Environment Variables
PORT=3333
NODE_ENV=development

# Database URLs
DEV_DATABASE_URL="postgresql://user:password@localhost:5432/hostinly?schema=public"
PROD_DATABASE_URL="postgresql://user:password@localhost:5432/hostinly_prod?schema=public"
DATABASE_URL=${DEV_DATABASE_URL}

DEV_DIRECT_URL="postgresql://user:password@localhost:5432/hostinly?schema=public"
PROD_DIRECT_URL="postgresql://user:password@localhost:5432/hostinly_prod?schema=public"
DIRECT_URL=${DEV_DIRECT_URL}

# Frontend Environment Variables
NEXT_PUBLIC_API_URL="https://hostinly-backend.onrender.com/api"
NEXT_PUBLIC_ADMIN_API_URL="https://hostinly-backend.onrender.com/api"
NEXT_PUBLIC_TEST_API_URL="http://localhost:3333/api"

# CORS
CORS_ORIGINS=https://hostinly-web.onrender.com,https://hostinly-web-prod.onrender.com,https://hostinly-admin.onrender.com,https://hostinly-admin-prod.onrender.com,https://hostinly.co,http://localhost:3333,http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3004

# Cloudinary (for file uploads)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Supabase (deprecated, remove after full switch)
# SUPABASE_URL=""
# SUPABASE_ANON_KEY=""
# SUPABASE_SERVICE_ROLE_KEY=""
