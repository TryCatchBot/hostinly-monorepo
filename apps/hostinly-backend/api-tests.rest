###

# Get engagements for a user
GET {{baseUrl}}/engagements/user/{{userId}}
Authorization: Bearer {{token}}

###

# Hire someone (Create engagement)
POST {{baseUrl}}/engagements
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "hostId": "{{userId}}",
  "staffId": "{{cohostId}}",
  "status": "ACTIVE",
  "startDate": "2026-06-15T09:00:00Z"
}

###

# Update engagement (Probation, End engagement)
PATCH {{baseUrl}}/engagements/{{engagementId}}
Content-Type: application/json
Authorization: Bearer {{token}}

